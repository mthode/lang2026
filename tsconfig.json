{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "scanner/**/*.ts",
    "parser/**/*.ts",
    "repl/**/*.ts",
    "shell/**/*.ts",
    "terminal/**/*.ts",
    "browser/**/*.ts",
    "test/**/*.ts",
    "index.ts"
  ]
}
